# Copy to .env on the remote machine and fill in real values.
# Never commit the real .env.

# Generate with: mix phx.gen.secret   (or: openssl rand -base64 64)
SECRET_KEY_BASE=

# Public hostname the app is served on (used to build URLs).
PHX_HOST=example.com

# Optional: libcluster DNS query. Leave empty for a single node.
DNS_CLUSTER_QUERY=
